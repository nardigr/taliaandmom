DATABASE_URL=postgresql://taljamom:taljamom@localhost:5432/taljamom?schema=public
# If using local PostgreSQL (no Docker), run: npm run db:setup
# It creates the taljamom user/database using your postgres superuser password.
AUTH_SECRET=            # required — openssl rand -base64 32
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAIL=
ADMIN_PASSWORD=
UPLOADS_DIR=/app/uploads
# Optional email notifications (all three required together)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SHOP_NOTIFICATION_EMAIL=
# AI assistant (Google Gemini — billing on key owner's account)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Dev/test only — enables fake card redirect + webhook provider
# ENABLE_TEST_PAYMENT_PROVIDER=true
# Future card payments (§7)
# PAYMENT_CARD_PROVIDER=
# CARD_MERCHANT_ID=
# CARD_SECRET=
