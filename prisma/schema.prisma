generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  KOSTUME
  FUSTANE
  KEMISHA
  PANTALLONA
  XHAKETA
  PALLTO
}

enum OrderStatus {
  E_RE
  KONFIRMUAR
  DERGUAR
  DOREZUAR
  ANULUAR
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  BANK_TRANSFER
  CARD
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

model Collection {
  id            String   @id @default(cuid())
  slug          String   @unique
  label         String
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  coverImageUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Product {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  description    String
  priceCents     Int
  compareAtCents Int?
  /// Collection slug (e.g. "pranvere") — editable via admin Collections
  season         String
  category       Category
  color          String
  sizes          String[]
  inStock        Boolean        @default(true)
  featured       Boolean        @default(false)
  images         ProductImage[]
  orderItems     OrderItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([season])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  path      String
  alt       String
  sortOrder Int     @default(0)
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  status        OrderStatus   @default(E_RE)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(UNPAID)
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  firstName     String
  lastName      String
  phone         String
  email         String?
  address       String
  city          String
  notes         String?
  subtotalCents Int
  shippingCents Int
  totalCents    Int
  items         OrderItem[]
  events        OrderEvent[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId])
  @@index([createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  nameSnapshot   String
  priceCentsSnap Int
  imageSnapshot  String?
  size           String?
  color          String?
  quantity       Int
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id              String           @id @default(cuid())
  email           String?          @unique
  phone           String
  firstName       String
  lastName        String
  city            String?
  address         String?
  notes           String?          @db.Text
  tags            String[]         @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  orders          Order[]
  contactRequests ContactRequest[]

  @@index([phone])
  @@index([lastName, firstName])
}

model ContactRequest {
  id         String    @id @default(cuid())
  source     String    @db.VarChar(30)
  fullName   String
  email      String
  phone      String?
  subject    String
  message    String    @db.Text
  status     String    @default("new") @db.VarChar(20)
  sessionId  String?
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventType String   @db.VarChar(40)
  fromValue String?
  toValue   String?
  note      String?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model Setting {
  key   String @id
  value String
}

model PageContent {
  id         String   @id @default(cuid())
  pageSlug   String
  sectionKey String
  value      String   @db.Text
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([pageSlug, sectionKey])
  @@index([pageSlug])
}

model SeoSettings {
  id                      String  @id @default("default")
  siteTitle               String  @default("Talja&mom — Modë femrash")
  siteDescription         String  @default("Elegancë për çdo stinë. Koleksione të përzgjedhura për çdo moment.")
  siteKeywords            String?
  businessName            String?
  businessType            String?
  businessDescription     String?
  businessPhone           String?
  businessEmail           String?
  businessAddress         String?
  businessCity            String?
  businessCountry         String?
  ogImage                 String?
  ga4MeasurementId        String?
  googleSiteVerification  String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model PageSeo {
  id              String   @id @default(cuid())
  pageSlug        String   @unique
  pageTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PageView {
  id         String   @id @default(cuid())
  path       String
  referrer   String?
  userAgent  String?
  country    String?
  city       String?
  deviceType String?
  browser    String?
  createdAt  DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([deviceType])
  @@index([browser])
}

model ChatSession {
  id             String        @id @default(uuid())
  locale         String        @default("sq") @db.VarChar(5)
  ipHash         String?       @map("ip_hash") @db.VarChar(64)
  userAgent      String?       @map("user_agent") @db.VarChar(500)
  status         String        @default("active") @db.VarChar(20)
  leadEmail      String?       @map("lead_email") @db.VarChar(255)
  leadName       String?       @map("lead_name") @db.VarChar(200)
  messageCount   Int           @default(0) @map("message_count")
  lastActivityAt DateTime      @default(now()) @map("last_activity_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  messages       ChatMessage[]

  @@index([createdAt])
  @@index([status])
  @@index([lastActivityAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id         String      @id @default(uuid())
  sessionId  String      @map("session_id")
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String      @db.VarChar(20)
  content    String      @db.Text
  toolName   String?     @map("tool_name") @db.VarChar(60)
  toolArgs   Json?       @map("tool_args")
  toolResult Json?       @map("tool_result")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@map("chat_messages")
}
